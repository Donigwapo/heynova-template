# Supabase configuration
# Copy this file to .env and set your real values.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_SUPABASE_FOLLOW_UP_FUNCTION=generate-follow-up-draft
VITE_SUPABASE_SEND_FOLLOW_UP_FUNCTION=send-follow-up
VITE_SUPABASE_MEETING_SUMMARY_FUNCTION=generate-meeting-summary
VITE_SUPABASE_CONTACT_SUGGESTION_FUNCTION=generate-followup-suggestion
VITE_SUPABASE_GOOGLE_OAUTH_START_FUNCTION=google-calendar-oauth-start
VITE_SUPABASE_GOOGLE_SYNC_FUNCTION=google-calendar-sync

# Supabase Edge Function secrets (set server-side via `supabase secrets set`)
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_OAUTH_REDIRECT_URI=https://<project-ref>.functions.supabase.co/google-calendar-oauth-callback
# PUBLIC_APP_URL=https://your-app-domain.com
# TOKEN_ENCRYPTION_KEY=<64-char-hex>
# VITE_SUPABASE_SEND_FOLLOW_UP_FUNCTION=send-follow-up
# (For Gmail send path, you can set this to gmail-send once wired in frontend)
# VITE_SUPABASE_GMAIL_OAUTH_START_FUNCTION=gmail-oauth-start

# GOOGLE_GMAIL_OAUTH_REDIRECT_URI=https://<project-ref>.functions.supabase.co/gmail-oauth-callback
